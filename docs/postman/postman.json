				},
				{
					"name": "Get CSRF Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract CSRF token from cookies",
									"const cookie = pm.cookies.get(\"csrf_token\");",
									"if (cookie) {",
									"    pm.environment.set(\"csrf_token\", cookie);",
									"    console.log(\"CSRF Token extracted:\", cookie);",
									"} else {",
									"    console.warn(\"CSRF Cookie not found\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/csrf",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"csrf"
							]
						}
					},
					"response": []
				},
				{
					"name": "Auth Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let response = pm.response.json();",
									"",
									"if (response.success && response.data.token) {",
									"    pm.environment.set(\"token\", response.data.token);",
									"    pm.environment.set(\"refresh_token\", response.data.refresh_token);",
									"    pm.environment.set(\"permission_hash\", response.data.user.permissions.hash);",
									"    pm.environment.set(\"permission_version\", response.data.user.permissions.version);",
									"    console.log(\"Auth successful - Token saved\");",
									"    console.log(\"Permission Hash:\", response.data.user.permissions.hash);",
									"} else {",
									"    console.warn(\"Login failed\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-CSRF-Token",
								"value": "{{csrf_token}}",
								"type": "text"
							},
							{
								"key": "Cookie",
								"value": "csrf_token={{csrf_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\" : \"admin@example.com\",\n    \"password\" : \"admin123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Enterprise login response with grouped permissions and permission hash for cache validation.\n\n**Response Structure:**\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"id\": \"uuid\",\n      \"email\": \"admin@example.com\",\n      \"name\": \"Admin User\",\n      \"role\": {\n        \"code\": \"admin\",\n        \"name\": \"Admin\",\n        \"level\": 10,\n        \"is_admin\": true\n      },\n      \"permissions\": {\n        \"version\": 1,\n        \"hash\": \"a1b2c3\",\n        \"grouped\": {\n          \"user\": [\"read\", \"write\", \"manage\"],\n          \"role\": [\"read\", \"manage\"]\n        },\n        \"count\": 25,\n        \"is_admin\": true\n      }\n    },\n    \"token\": \"jwt_access_token\",\n    \"refresh_token\": \"jwt_refresh_token\",\n    \"expires_in\": 900,\n    \"refresh_in\": 604800,\n    \"token_type\": \"Bearer\"\n  }\n}\n```"
					},
					"response": []
				},
