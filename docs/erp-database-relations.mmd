    Country {
        uint ID PK
        string Name
    }
    
    Province {
        uint ID PK
        uint CountryID FK
        string Name
    }
    
    City {
        uint ID PK
        uint ProvinceID FK
        string Name
    }
    
    District {
        uint ID PK
        uint CityID FK
        string Name
    }
    
    Village {
        uint ID PK
        uint DistrictID FK
        string Name
    }
    
    Country ||--o{ Province : "has"
    Province ||--o{ City : "has"
    City ||--o{ District : "has"
    District ||--o{ Village : "has"
    
    %% ============================================================
    %% MASTER DATA - ORGANIZATION
    %% ============================================================
    
    Company {
        uint ID PK
        uint VillageID FK
        uint DirectorID FK
        string Name
        string Address
        string Email
        string NPWP
        string NIB
        bool IsApproved
        uint CreatedBy FK
        uint ApprovedBy FK
    }
    
    Division {
        uint ID PK
        string Name
    }
    
    JobPosition {
        uint ID PK
        string Name
    }
    
    BusinessUnit {
        uint ID PK
        string Name
        string Description
    }
    
    BusinessType {
        uint ID PK
        string Name
        string Description
    }
    
    Area {
        uint ID PK
        string Name
    }
    
    AreaSupervisor {
        uint ID PK
        string Name
    }
    
