# ===========================================
# GIMS ERP - Development Environment Variables
# ===========================================
# Copy this file to .env for local development
#
# USAGE OPTIONS:
# 1. Full Docker Stack (default):
#    cp .env.development.example .env
#    docker-compose up -d
#
# 2. Local Go + Docker DB only:
#    cp .env.development.example .env
#    # Uncomment LOCAL_GO_MODE section below
#    docker-compose up -d postgres redis
#    go run cmd/api/main.go

# Server Configuration
PORT=8080
ENV=development
GIN_MODE=debug
APP_TIMEZONE=Asia/Jakarta  # IANA timezone (e.g., Asia/Jakarta, America/New_York)

# Database Configuration (Docker internal - used by docker-compose)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gims_erp
DB_SSLMODE=disable
DB_EXTERNAL_PORT=5434

# ===========================================
# LOCAL_GO_MODE - Uncomment below for local Go development
# ===========================================
# DB_HOST=localhost
# DB_PORT=5434
# REDIS_HOST=localhost
# ===========================================

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TTL=24
JWT_REFRESH_TTL=7

# Cerebras AI Configuration
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage Configuration
STORAGE_UPLOAD_DIR=./uploads
STORAGE_BASE_URL=/uploads
STORAGE_MAX_UPLOAD_SIZE=10485760

# Seed Configuration
SEED_DEFAULT_PASSWORD=admin123
