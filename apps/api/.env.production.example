# ===========================================
# GIMS ERP - Production Environment Variables
# ===========================================
# Copy this file to .env for production deployment

# Server Configuration
PORT=8080
ENV=production
GIN_MODE=release

# Database Configuration (Docker internal)
# Note: DB_HOST and DB_PORT are set to docker service names internally
DB_USER=postgres
DB_PASSWORD=your-secure-production-password
DB_NAME=gims_erp
DB_SSLMODE=disable
DB_EXTERNAL_PORT=5434

# JWT Configuration (CRITICAL: Change in production!)
JWT_SECRET=your-production-secret-key-must-be-at-least-32-characters-long
JWT_ACCESS_TTL=24
JWT_REFRESH_TTL=7

# Cerebras AI Configuration
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=your-production-cerebras-api-key

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_DB=0

# Storage Configuration
STORAGE_BASE_URL=/uploads
STORAGE_MAX_UPLOAD_SIZE=10485760

# Seed Configuration
SEED_DEFAULT_PASSWORD=change-this-secure-password
