# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================
# ⚠️  SECURITY WARNING:
# - Never commit this file to version control
# - Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# - Rotate credentials regularly
# - Enable audit logging for all access
# ===========================================

# Server Configuration
PORT=8087
APP_ENV=production

# Startup Behavior - PRODUCTION SETTINGS
RUN_MIGRATIONS=false  # ⚠️ Run migrations manually in production with proper testing
RUN_SEEDERS=false     # ⚠️ CRITICAL: NEVER enable seeders in production

# Database Configuration - Use managed database service
DB_HOST=prod-rds.region.rds.amazonaws.com  # Example: AWS RDS
DB_PORT=5432
DB_USER=gims_prod_user
DB_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER  # Use AWS Secrets Manager / Vault
DB_NAME=gims_erp_production
DB_SSLMODE=require  # ⚠️ Always require SSL in production
DB_MAX_OPEN_CONNS=100  # Tune based on instance size
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h

# JWT Configuration - Use strong secrets
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING_FROM_SECRETS_MANAGER
JWT_ACCESS_TTL=15  # Shorter TTL for production (15 minutes)
JWT_REFRESH_TTL=7  # 7 days

# JWT Key Rotation (Enterprise feature)
JWT_ACCESS_KEYS={"kid1":"secret1","kid2":"secret2"}  # Multiple keys for zero-downtime rotation
JWT_REFRESH_KEYS={"kid1":"secret1","kid2":"secret2"}
JWT_ACCESS_KID=kid2  # Active key ID
JWT_REFRESH_KID=kid2

# Cerebras AI Configuration (if used)
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=CHANGE_ME_FROM_SECRETS_MANAGER

# Redis Configuration - Use managed Redis (ElastiCache, etc.)
REDIS_HOST=prod-redis.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_FROM_SECRETS_MANAGER
REDIS_DB=0
REDIS_TLS=true  # Enable TLS for production

# Storage Configuration - Use S3/Cloud Storage
STORAGE_TYPE=s3  # Options: local, s3, gcs, azure
STORAGE_S3_BUCKET=gims-prod-uploads
STORAGE_S3_REGION=ap-southeast-1
STORAGE_S3_ACCESS_KEY=CHANGE_ME_FROM_SECRETS_MANAGER
STORAGE_S3_SECRET_KEY=CHANGE_ME_FROM_SECRETS_MANAGER
STORAGE_BASE_URL=https://cdn.yourdomain.com/uploads
STORAGE_MAX_UPLOAD_SIZE=10485760  # 10MB

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100

# Logging & Monitoring
LOG_LEVEL=info  # Options: debug, info, warn, error
LOG_FORMAT=json  # Structured logging for log aggregation
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_ENABLED=true
DATADOG_API_KEY=CHANGE_ME_FROM_SECRETS_MANAGER

# Security Headers
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000  # 1 year
SECURITY_CSP_ENABLED=true

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_FROM_SECRETS_MANAGER
SMTP_FROM=noreply@yourdomain.com

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30s

# Feature Flags (optional)
FEATURE_AI_ENABLED=true
FEATURE_AUDIT_LOG=true
FEATURE_TWO_FACTOR_AUTH=true

# Compliance
DATA_RETENTION_DAYS=2555  # 7 years for SOX compliance
AUDIT_LOG_RETENTION_DAYS=2555
PII_ENCRYPTION_ENABLED=true

# ===========================================
# DEPLOYMENT CHECKLIST
# ===========================================
# [ ] All secrets moved to secrets manager
# [ ] SSL/TLS enabled for all connections
# [ ] Database backups configured
# [ ] Monitoring and alerting setup
# [ ] Log aggregation configured
# [ ] Rate limiting enabled
# [ ] CORS properly configured
# [ ] Security headers enabled
# [ ] Disaster recovery plan tested
# [ ] Incident response plan documented
# ===========================================
