# Server Configuration
PORT=8087
APP_ENV=development  # Options: development, staging, production

# Startup Behavior
RUN_MIGRATIONS=true  # Auto-run migrations on startup
RUN_SEEDERS=true     # Auto-run seeders on startup (NEVER set to true in production)

# Database Configuration
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gims_erp_db
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TTL=24
JWT_REFRESH_TTL=7

# Cerebras AI Configuration
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Redis Configuration    
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# Storage Configuration
STORAGE_UPLOAD_DIR=./uploads
STORAGE_BASE_URL=/uploads
STORAGE_MAX_UPLOAD_SIZE=10485760

SEED_DEFAULT_PASSWORD=admin123